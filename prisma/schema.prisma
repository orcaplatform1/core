generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(cuid())
  email             String?            @unique
  phone             String?            @unique
  password          String?
  fullName          String
  username          String?            @unique
  avatarUrl         String?
  dateOfBirth       DateTime?
  education         EducationLevel?
  gender            Gender?
  occupation        OccupationType?
  role              Role               @default(GUEST)
  toolsSubscription SubscriptionStatus @default(NONE)

  googleId          String?  @unique
  appleId           String?  @unique
  profileComplete   Boolean  @default(true)

  emailVerified            Boolean   @default(false)
  emailVerificationToken   String?
  phoneVerified             Boolean   @default(false)
  phoneVerificationCode     String?
  phoneVerificationExpires  DateTime?
  passwordResetToken       String?
  passwordResetExpires     DateTime?
  refreshTokenHash         String?

  dailyGoalLessons   Int @default(1)
  weeklyGoalLessons  Int @default(5)
  streakGoalDays     Int @default(30)

  currentStreak     Int      @default(0)
  longestStreak     Int      @default(0)
  lastActivityDate  DateTime?
  lastLoginAt       DateTime?

  sessionId         String?
  bannedUntil       DateTime?
  banCount          Int       @default(0)

  promoCode         String? @unique
  referredByStaffId String?
  financialProfile  FinancialProfile?

  payments          Payment[]        @relation("PaymentBuyer")
  referredPayments  Payment[]        @relation("PaymentReferrer")
  quizAttempts      QuizAttempt[]
  progress          Progress[]
  certificates      Certificate[]
  subscriptions     Subscription[]
  enrollments       Enrollment[]
  loginLogs         LoginLog[]
  backtestTrades    BacktestTrade[]
  notifications     Notification[]
  statsSnapshots    StatsSnapshot[]
  userBadges        UserBadge[]
  commissionsEarned Commission[]
  conversation      Conversation?
  simulationAccount SimulationAccount?

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Lead {
  id               String   @id @default(cuid())
  phone            String   @unique
  financialProfile FinancialProfile
  answers          Json?
  staffPromoCode   String?
  convertedUserId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Commission {
  id        String   @id @default(cuid())
  staffId   String
  staff     User     @relation(fields: [staffId], references: [id], onDelete: Cascade)
  paymentId String
  amount    Float
  rate      Float
  createdAt DateTime @default(now())
}

model Program {
  id          String  @id @default(cuid())
  title       String
  description String?
  coverImageUrl String?
  level ProgramLevel?
  durationHours Int?

  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])

  modules Module[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Module {
  id          String  @id @default(cuid())
  title       String
  description String?
  order       Int @default(1)

  programId String
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  lessons Lesson[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lesson {
  id          String  @id @default(cuid())
  title       String
  description String?
  order       Int @default(1)

  videoUrl        String?
  pdfUrl          String?
  durationSeconds Int?

  resources   LessonResource[]
  quizzes     Quiz[]
  moduleId    String
  module      Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LessonResource {
  id       String @id @default(cuid())
  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  name     String
  url      String

  createdAt DateTime @default(now())
}

model Quiz {
  id          String     @id @default(cuid())
  title       String
  description String?
  questions   Question[]

  timeLimitMinutes Int @default(20)

  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Question {
  id          String   @id @default(cuid())
  title       String
  description String?
  explanation String?
  answers     Answer[]

  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Answer {
  id        String  @id @default(cuid())
  text      String
  isCorrect Boolean @default(false)

  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuizAttempt {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId String

  lessonId String
  moduleId String
  programId String

  totalQuestions Int @default(0)
  correctAnswers Int @default(0)
  wrongAnswers Int @default(0)
  percentage Int @default(0)
  score Int @default(0)

  passed Boolean @default(false)
  grade QuizGrade?
  expired Boolean @default(false)

  startedAt DateTime @default(now())
  endedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuizAnswer {
  id String @id @default(cuid())

  quizAttemptId String

  questionId String

  selectedAnswerId String

  isCorrect Boolean

  timeSpent Int @default(0)

  answeredAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([quizAttemptId, questionId])
}

model Progress {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  programId String?
  moduleId String?
  lessonId String?
  quizId String?

  completed Boolean @default(false)
  progress Int @default(0)

  lastAccessAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
}

model Certificate {
  id        String   @id @default(cuid())
  number    Int      @unique @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  programId String
  code      String   @unique
  studentName String?
  issuedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, programId])
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    SubscriptionStatus @default(ACTIVE)
  startedAt DateTime @default(now())
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  programId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, programId])
}

model Payment {
  id         String        @id @default(cuid())
  userId     String
  user       User          @relation("PaymentBuyer", fields: [userId], references: [id], onDelete: Restrict)
  amount     Float
  currency   String
  method     PaymentMethod
  status     PaymentStatus @default(PENDING)
  receiptUrl String?
  approvedAt DateTime?

  cryptoProvider    CryptoProvider?
  promoCodeUsed     String?
  discountApplied   Float?
  referredByStaffId String?
  referredByStaff   User?    @relation("PaymentReferrer", fields: [referredByStaffId], references: [id])

  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  programs  Program[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Badge {
  id          String      @id @default(cuid())
  name        String      @unique
  description String
  triggerType BadgeTriggerType @default(CUSTOM)
  requiredCount Int @default(1)
  users       UserBadge[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           MessageRole
  content        String
  createdAt      DateTime     @default(now())
}

model SimulationAccount {
  id        String           @id @default(cuid())
  userId    String           @unique
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Float            @default(10000)
  trades    SimulatedTrade[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model SimulatedTrade {
  id         String            @id @default(cuid())
  accountId  String
  account    SimulationAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  symbol     String
  direction  TradeDirection
  quantity   Float
  entryPrice Float
  exitPrice  Float?
  pnl        Float?
  status     TradeStatus       @default(OPEN)
  createdAt  DateTime          @default(now())
  closedAt   DateTime?
}

model HistoricalCandle {
  id        String    @id @default(cuid())
  symbol    String
  assetType AssetType @default(CRYPTO)
  timestamp DateTime
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float?

  @@unique([symbol, timestamp])
  @@index([symbol, timestamp])
}

model BacktestTrade {
  id         String            @id @default(cuid())
  userId     String
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol     String
  direction  TradeDirection
  quantity   Float
  entryPrice Float
  entryDate  DateTime
  exitPrice  Float?
  exitDate   DateTime?
  pnl        Float?
  status     TradeStatus       @default(OPEN)
  createdAt  DateTime          @default(now())
}

model LoginLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ip         String?
  userAgent  String?
  loggedInAt DateTime @default(now())

  @@index([userId])
}

model LiveLesson {
  id              String   @id @default(cuid())
  title           String
  scheduledAt     DateTime
  durationMinutes Int
  discordLink     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
}

model StatsSnapshot {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart    DateTime
  overallScore Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, weekStart])
}

model ScanResult {
  id        String   @id @default(cuid())
  results   Json
  createdAt DateTime @default(now())
}

model WinRateCache {
  id             String         @id @default(cuid())
  symbol         String
  direction      TradeDirection
  winRatePercent Int?
  calculatedAt   DateTime       @default(now())

  @@unique([symbol, direction])
}

model Quote {
  id         String @id @default(cuid())
  order      Int    @unique
  text       String
  author     String
  profession String
}

enum QuizGrade {
  FAILED
  SUCCESS
  GOOD
  EXCELLENT
}

enum Role {
  GUEST
  STUDENT
  STAFF
  SUPER_ADMIN
}

enum SubscriptionStatus {
  NONE
  ACTIVE
  EXPIRED
}

enum PaymentMethod {
  CARD
  CRYPTO
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MessageRole {
  USER
  MENTOR
}

enum TradeDirection {
  BUY
  SELL
}

enum TradeStatus {
  OPEN
  CLOSED
}

enum AssetType {
  CRYPTO
  FOREX
}

enum EducationLevel {
  ILKOGRETIM
  LISE
  ONLISANS
  LISANS
  DOKTORA
}

enum OccupationType {
  OGRENCI
  ISSIZ
  SERBEST_MESLEK
  OZEL_SEKTOR
  KAMU
  YONETICI
}

enum NotificationType {
  NEW_LESSON
  NEW_PROGRAM
  QUIZ_RESULT
  AI_SUGGESTION
  CERTIFICATE_READY
  ANNOUNCEMENT
  LIVE_LESSON_REMINDER
  SYSTEM
}

enum BadgeTriggerType {
  FIRST_LESSON
  QUIZ_PASS_COUNT
  STREAK_DAYS
  BACKTEST_COUNT
  SIMULATION_COUNT
  CUSTOM
}

enum FinancialProfile {
  BASLANGIC
  ORTA
  ILERI
  UZMAN
}

enum CryptoProvider {
  BINANCE
  OKX
  BYBIT
}

enum Gender {
  ERKEK
  KADIN
}

enum ProgramLevel {
  BASLANGIC
  ORTA
  ILERI
}

model ChartDrawing {
  id        String   @id @default(cuid())
  userId    String
  symbol    String
  context   String
  drawings  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, symbol, context])
}
